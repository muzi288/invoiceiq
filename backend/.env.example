# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/invoiceiq

# JWT
JWT_SECRET_KEY=your-secret-key-here-minimum-32-characters
JWT_ALGORITHM=HS256
JWT_EXPIRY_MINUTES=60

# Azure Blob Storage
AZURE_STORAGE_CONNECTION_STRING=your-connection-string
AZURE_STORAGE_CONTAINER_NAME=invoiceiq-files

# AI
ANTHROPIC_API_KEY=your-anthropic-api-key
GEMINI_API_KEY=your-gemini-api-key

# Redis (Celery)
REDIS_URL=redis://localhost:6379

# App
APP_ENV=development
APP_PORT=8000
FRONTEND_URL=http://localhost:5173

# Email (optional — logs to console when unset)
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_USE_TLS=true
